{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/api/index.js",
      "routePrefix": "/_/backend"
    }
  },
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!api/|_/).*)",
      "destination": "/index.html"
    }
  ]
}
