PORT=5000
NODE_ENV=development

# Database Settings
# Set DB_DIALECT to 'postgres' and specify DATABASE_URL in your hosting dashboard
DB_DIALECT=postgres
DATABASE_URL=your_postgresql_database_url_here

# JWT Configuration
# A secure, randomly generated 256-bit hexadecimal string for signing tokens
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d
